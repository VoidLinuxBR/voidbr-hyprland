package() {
	# Verify default folder
	if [ -d "${srcdir}/${pkgname}/${pkgname}" ]; then
		InternalDir="${srcdir}/${pkgname}/${pkgname}"
	else
		InternalDir="${srcdir}/${pkgname}"
	fi

	cd "${srcdir}/${pkgname}"
	# Copiar a estrutura de /etc, /usr e /opt para /
	local dirs=("boot" "etc" "opt" "usr")
	for dir in "${dirs[@]}"; do
		if [ -d "${InternalDir}/${dir}" ]; then
			cp -a "${InternalDir}/${dir}" "${pkgdir}/"
		fi
	done

	# Install license file if present
	if [ -f "LICENSE" ]; then
		install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
	fi

	# Install documentation if present
	if [ -f "README.md" ]; then
		install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
	fi
}

pre_install() {
	log "Iniciando instalação"
}

post_install() {
	log "Ativando serviços"

	ln -sf /etc/sv/dbus /var/service/ 2>/dev/null || true
	ln -sf /etc/sv/elogind /var/service/ 2>/dev/null || true
	ln -sf /etc/sv/NetworkManager /var/service/ 2>/dev/null || true
	ln -sf /etc/sv/rtkit /var/service/ 2>/dev/null || true

	log "Finalizando instalação"
}

